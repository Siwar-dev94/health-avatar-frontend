* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #080e1a; color: #e2e8f4; height: 100vh; overflow: hidden; }
#root { height: 100vh; }
.app-layout { display: flex; height: 100vh; }
.avatar-section { flex: 3.5; position: relative; background: #080e1a; border-right: 1px solid #131f35; }
.avatar-section canvas { width: 100% !important; height: 100% !important; }
.status-pill { position: absolute; top: 20px; left: 50%; transform: translateX(-50%); padding: 6px 20px; border-radius: 99px; font-size: 12px; font-weight: 500; border: 1px solid; white-space: nowrap; }
.s-idle  { background: rgba(5,46,22,0.9); color: #4ade80; border-color: #166534; }
.s-speak { background: rgba(7,25,82,0.9); color: #60a5fa; border-color: #1e40af; }
.s-think { background: rgba(67,20,7,0.9); color: #fb923c; border-color: #9a3412; }
.chat-panel { flex: 0 0 300px; display: flex; flex-direction: column; background: #0c1422; min-height: 0; border-left: 1px solid #131f35; }
.chat-header { padding: 14px 18px; border-bottom: 1px solid #131f35; display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.header-dot { width: 8px; height: 8px; border-radius: 50%; background: #4ade80; flex-shrink: 0; }
.header-title { font-size: 14px; font-weight: 600; color: #e2e8f4; }
.messages-list { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; min-height: 0; }
.messages-list::-webkit-scrollbar { width: 3px; }
.messages-list::-webkit-scrollbar-thumb { background: #1e2d45; border-radius: 99px; }
.msg { display: flex; gap: 7px; align-items: flex-end; }
.msg-user { flex-direction: row-reverse; }
.msg-icon { width: 26px; height: 26px; border-radius: 50%; background: #0f2a4f; color: #60a5fa; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid #1e3a6e; }
.bubble { max-width: 85%; padding: 9px 12px; border-radius: 14px; font-size: 13px; line-height: 1.55; }
.msg-assistant .bubble { background: #111d2e; color: #c4d4ec; border: 1px solid #1a2d48; border-bottom-left-radius: 4px; }
.msg-user .bubble { background: #153566; color: #dbeafe; border: 1px solid #1e4080; border-bottom-right-radius: 4px; }
.bubble-loading { display: flex; gap: 5px; align-items: center; padding: 12px 14px; }
.dot-anim { width: 6px; height: 6px; border-radius: 50%; background: #3a5070; animation: bounce 1.3s ease-in-out infinite; }
.dot-anim:nth-child(2) { animation-delay: 0.18s; }
.dot-anim:nth-child(3) { animation-delay: 0.36s; }
@keyframes bounce { 0%,80%,100%{transform:translateY(0);opacity:0.5} 40%{transform:translateY(-7px);opacity:1} }
.input-row { display: flex; gap: 7px; padding: 12px 14px; border-top: 1px solid #131f35; background: #080e1a; flex-shrink: 0; }
.text-input { flex: 1; padding: 10px 13px; background: #0f1a2e; border: 1px solid #1a2d48; border-radius: 10px; color: #e2e8f4; font-size: 13px; outline: none; transition: border-color 0.2s; font-family: inherit; }
.text-input:focus { border-color: #2a5298; }
.text-input::placeholder { color: #3a5070; }
.text-input:disabled { opacity: 0.5; }
.send-btn { width: 38px; height: 38px; border-radius: 10px; border: 1px solid #1e4080; background: #112a5e; color: #60a5fa; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.send-btn:hover:not(:disabled) { background: #1a3a80; }
.send-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.disclaimer { text-align: center; font-size: 10px; color: #1e2d45; padding: 6px; border-top: 1px solid #0f1a2e; flex-shrink: 0; }
@keyframes pulse { 0%,100%{box-shadow:0 0 24px #ef444488} 50%{box-shadow:0 0 40px #ef4444cc} }
@keyframes wave { 0%,100%{transform:scaleY(0.4)} 50%{transform:scaleY(1)} }
@media (max-width: 768px) { .app-layout{flex-direction:column} .avatar-section{flex:0 0 55vh} .chat-panel{flex:1;min-width:0} }

